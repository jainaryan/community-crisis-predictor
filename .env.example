REDDIT_CLIENT_ID=your_client_id_here
REDDIT_CLIENT_SECRET=your_client_secret_here
REDDIT_USER_AGENT=CommunityMentalHealthMonitor/1.0
PRIVACY_SALT=change_this_to_a_random_string

# Optional: LLM providers for weekly brief generation. Priority order: OpenRouter → Anthropic → OpenAI → template fallback.
# OpenRouter (recommended — supports free models, OpenAI-compatible): https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Override the default model (meta-llama/llama-3.3-8b-instruct:free). Pick any model from openrouter.ai/models.
OPENROUTER_MODEL=meta-llama/llama-3.3-8b-instruct:free
# Anthropic / OpenAI (used only if OPENROUTER_API_KEY is not set)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional: cap how many recent weeks get LLM/template briefs per subreddit (default: all weeks with predictions).
WEEKLY_NARRATIVE_MAX_WEEKS=12
